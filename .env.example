APP_NAME="Happy Pizza"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# En producción (Railway, etc.) usa https://tu-dominio... y coincide con el dominio público.
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Correo: "log" en local; en producción "brevo-api" (HTTPS, recomendado en Railway) o "brevo"/SMTP o sendgrid.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# Debe coincidir con un remitente verificado en Brevo (Senders → dominios o Single sender). Si usas un correo genérico tipo hello@example.com sin verificar, Brevo puede no entregar ni contabilizar el envío.
MAIL_FROM_ADDRESS="example@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# SendGrid (SMTP): https://docs.sendgrid.com/for-developers/sending-email/getting-started-smtp
# Crear API Key en SendGrid; el remitente MAIL_FROM_ADDRESS debe estar verificado (Single Sender o dominio).
# MAIL_MAILER=sendgrid
# SENDGRID_API_KEY=
# Opcional (valores por defecto suelen bastar):
# MAIL_SENDGRID_HOST=smtp.sendgrid.net
# MAIL_SENDGRID_PORT=587
# MAIL_SENDGRID_USERNAME=apikey

# Brevo por API HTTPS (recomendado en Railway: muchos PaaS bloquean SMTP 587 / QDISC_DROP en el worker).
# Requiere el paquete symfony/http-client en composer (ya incluido en este proyecto).
# Panel → SMTP & API → API keys → clave xkeysib-... (no uses xsmtpsib-... de SMTP aquí).
# MAIL_MAILER=brevo-api
# BREVO_API_KEY=
#
# Brevo (SMTP): panel → SMTP & API → SMTP. MAIL_BREVO_SMTP_KEY empieza por xsmtpsib-...
# MAIL_MAILER=brevo
# MAIL_BREVO_LOGIN=
# MAIL_BREVO_SMTP_KEY=
# MAIL_BREVO_HOST=smtp-relay.brevo.com
# MAIL_BREVO_PORT=587
# Si ves error "Peer certificate CN=... did not match smtp-relay.brevo.com", prueba el host que indica el certificado, p. ej.:
# MAIL_BREVO_HOST=smtp-relay-offshore-southamerica-east-v2.sendinblue.com
# Solo desarrollo / último recurso (menos seguro):
# MAIL_SMTP_VERIFY_PEER=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
